{
  "name": "tapwire",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch --ignore 'certs/**' --ignore 'data/**' --ignore 'build/**' --ignore '*.mjs' server.ts",
    "start": "vite build && NODE_ENV=production npx tsx server.ts",
    "typecheck": "tsc"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "compression": "^1.7.4",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "node-forge": "^1.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.5.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zustand": "^4.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "@types/node-forge": "^1.3.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vite-tsconfig-paths": "^5.0.1"
  }
